# i3 config file (v4)
#
# Configuración personalizada por Antigravity para Parrot OS
# Basado en la estética fluida de Hyprland con atajos Super y Vim.
#

# Fuentes
font pango:CaskaydiaCove Nerd Font 10

# Tecla modificadora principal: Mod4 (Tecla Super / Windows)
set $mod Mod4

# Autostart de servicios esenciales y utilidades
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet
exec --no-startup-id lxpolkit
exec --no-startup-id greenclip daemon
exec --no-startup-id xcape -e 'Super_L=Super_L|d'

# Autostart para fondos de pantalla, composición de ventanas y barra superior
exec_always --no-startup-id feh --bg-fill /home/wlaz/.dotfiles/assets/wallpaper/wallpaper.png
exec_always --no-startup-id picom --config /home/wlaz/.config/picom/picom.conf -b
exec_always --no-startup-id /home/wlaz/.config/polybar/launch.sh
exec_always --no-startup-id /home/wlaz/.config/i3/scripts/alternating_layouts.py

# Control de Audio
bindsym XF86AudioRaiseVolume exec --no-startup-id wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 10%+
bindsym XF86AudioLowerVolume exec --no-startup-id wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 10%-
bindsym XF86AudioMute exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle

# Control de Brillo (Fn + Izquierda / Derecha)
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +10%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 10%-

# Atajos de navegación Vim (h, j, k, l)
set $left h
set $down j
set $up k
set $right l

# Modificador para arrastrar ventanas flotantes (Mouse + Super)
floating_modifier $mod

# Arrastrar ventanas tiling desde su barra de título
tiling_drag modifier titlebar

# Iniciar Terminal (Kitty)
bindsym $mod+Return exec kitty
bindsym $mod+Shift+Return exec kitty

# Cerrar ventana enfocada (estilo Hyprland)
bindsym $mod+q kill
bindsym $mod+Shift+q kill

# Lanzador de aplicaciones por categorías (Rofi)
bindsym $mod+d exec --no-startup-id /home/wlaz/.config/rofi/scripts/rofi-category-launcher.py

# Captura de pantalla de área seleccionada directa al portapapeles (Impr Pant)
bindsym Print exec --no-startup-id "maim -s | xclip -selection clipboard -t image/png && notify-send 'Captura' 'Selección copiada al portapapeles'"

# Cambiar foco de ventana (Vim keys)
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

# Cambiar foco de ventana (Teclas de flechas)
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Mover ventana enfocada (Vim keys)
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

# Mover ventana enfocada (Teclas de flechas)
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Dividir ventanas en orientación horizontal ($mod+b) e vertical ($mod+v)
bindsym $mod+b split h
bindsym $mod+v split v

# Entrar en modo pantalla completa
bindsym $mod+f fullscreen toggle

# Cambiar diseño del contenedor (stacking, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+t layout toggle split

# Abrir el gestor de archivos (Caja)
bindsym $mod+e exec --no-startup-id caja

# Alternar modo tiling / flotante
bindsym $mod+Shift+space floating toggle
bindsym $mod+Shift+f floating toggle

# Alternar foco entre ventana flotante y tiling
bindsym $mod+space focus mode_toggle

# Enfocar contenedor padre
bindsym $mod+a focus parent

# Enviar ventana al scratchpad (zona oculta)
bindsym $mod+Shift+minus move scratchpad

# Mostrar/ocultar ventanas del scratchpad
bindsym $mod+minus scratchpad show

# Definir nombres para áreas de trabajo (workspaces)
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Cambiar a espacio de trabajo
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Mover ventana enfocada a espacio de trabajo
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Recargar archivo de configuración de i3
bindsym $mod+Shift+c reload
# Reiniciar i3 en caliente (mantiene las ventanas abiertas)
bindsym $mod+Shift+r restart
# Menú de apagado y salida (Rofi Powermenu)
bindsym $mod+Shift+e exec --no-startup-id /home/wlaz/.config/rofi/powermenu/powermenu.sh
# Selector de Fondo de Pantalla (Rofi Wallpaper Changer)
bindsym $mod+Shift+w exec --no-startup-id /home/wlaz/.config/rofi/scripts/rofi-wallpaper-changer.sh

# Gaps (Espacios entre ventanas)
gaps inner 12
gaps outer 6

# Bordes de ventana modernos y delgados
default_border pixel 2
default_floating_border normal

# Paleta de colores Peru Cyber para marcos de ventana
# class                 border  backgr. text    indicator child_border
client.focused          #ff1a1a #080808 #ffffff #ff4d4d   #ff1a1a
client.focused_inactive #121212 #080808 #888888 #121212   #121212
client.unfocused        #080808 #080808 #555555 #080808   #080808
client.urgent           #ff1a1a #ff1a1a #ffffff #ff1a1a   #ff1a1a
client.placeholder      #000000 #0c0c0c #ffffff #000000   #000000
client.background       #080808

# Redimensionar ventanas
mode "resize" {
        bindsym $left       resize shrink width 10 px or 10 ppt
        bindsym $down       resize grow height 10 px or 10 ppt
        bindsym $up         resize shrink height 10 px or 10 ppt
        bindsym $right      resize grow width 10 px or 10 ppt

        bindsym Left        resize shrink width 10 px or 10 ppt
        bindsym Down        resize grow height 10 px or 10 ppt
        bindsym Up          resize shrink height 10 px or 10 ppt
        bindsym Right       resize grow width 10 px or 10 ppt

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

# Nota: La barra de i3 predeterminada (i3bar) está desactivada ya que iniciamos Polybar.
